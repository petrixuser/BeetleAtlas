            <project id="SNIB-S150-Invertebrados-Invert_recuperada">
                <title>Biodiversidad acuática del río Amacuzac, Morelos, México (Invert_recuperada)</title>
                <personnel>
                    <individualName>
                    <givenName>Rubén</givenName>
                    <surName>Castro Franco</surName>
                    </individualName>
                    <role>PRINCIPAL_INVESTIGATOR</role>
                </personnel>
